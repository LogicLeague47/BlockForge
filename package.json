{
  "name": "minecraft-clone",
  "version": "1.0.0",
  "description": "A voxel sandbox Minecraft clone built with Three.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "build:cg": "vite build --mode cg && node scripts/strip-cg.mjs",
    "package": "bash package.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "simplex-noise": "^4.0.1",
    "three": "^0.169.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
